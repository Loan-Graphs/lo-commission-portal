# ─── Convex ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# ─── App ──────────────────────────────────────────────────────────────────────
# Base URL (used in QB OAuth redirect + Plaid webhook)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Plaid ────────────────────────────────────────────────────────────────────
# Sign up at: https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
# Options: sandbox | development | production
PLAID_ENV=sandbox
# Sandbox test credentials: username=user_good, password=pass_good

# ─── QuickBooks Online ────────────────────────────────────────────────────────
# Sign up at: https://developer.intuit.com
QB_CLIENT_ID=
QB_CLIENT_SECRET=
# Options: sandbox | production
QB_ENVIRONMENT=sandbox
QB_REDIRECT_URI=http://localhost:3000/api/quickbooks/callback

# ─── Plaid Webhook (local dev) ────────────────────────────────────────────────
# Plaid webhooks require a public URL. For local dev, use a tunnel:
#   npx ngrok http 3000
#   cloudflared tunnel --url http://localhost:3000
# Then set your webhook URL in the Plaid dashboard to:
#   https://<tunnel-url>/api/plaid/webhook
